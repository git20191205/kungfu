{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "请求 QPS",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=~\"$application\"}[1m])) by (application)",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "P99 响应时间",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=~\"$application\"}[5m])) by (le, application))",
          "legendFormat": "{{application}} P99",
          "refId": "A"
        }
      ]
    },
    {
      "title": "HTTP 错误率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "color": { "mode": "palette-classic" }, "min": 0, "max": 1 },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=~\"$application\",status=~\"5..\"}[5m])) by (application) / sum(rate(http_server_requests_seconds_count{application=~\"$application\"}[5m])) by (application)",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "JVM 堆内存使用",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=~\"$application\", area=\"heap\"}",
          "legendFormat": "{{application}} - {{id}}",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_max_bytes{application=~\"$application\", area=\"heap\"}",
          "legendFormat": "{{application}} - {{id}} (max)",
          "refId": "B"
        }
      ]
    },
    {
      "title": "GC 暂停时间",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{application=~\"$application\"}[5m])",
          "legendFormat": "{{application}} - {{cause}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "活跃线程数",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=~\"$application\"}",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "系统 CPU 使用率",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.6 }, { "color": "red", "value": 0.8 }] } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "system_cpu_usage{application=~\"$application\"}",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Kafka 消费者 Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "spring_kafka_listener_seconds_count{application=~\"$application\"}",
          "legendFormat": "{{application}} - {{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "数据库连接池",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=~\"$application\"}",
          "legendFormat": "{{application}} active",
          "refId": "A"
        },
        {
          "expr": "hikaricp_connections_pending{application=~\"$application\"}",
          "legendFormat": "{{application}} pending",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["seckill", "spring-boot"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(jvm_memory_used_bytes, application)",
        "includeAll": true,
        "multi": true,
        "name": "application",
        "query": "label_values(jvm_memory_used_bytes, application)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "title": "秒杀系统监控大盘",
  "uid": "seckill-dashboard",
  "version": 1
}
